# Anthropic Proxy Configuration
# Copy this file to .env and fill in your values

# Required: Upstream API endpoint
# Examples:
#   OpenRouter: https://openrouter.ai/api
#   OpenAI: https://api.openai.com
#   Local LLM: http://localhost:11434
UPSTREAM_BASE_URL=https://openrouter.ai/api

# Optional: API key for upstream service (required for most providers)
UPSTREAM_API_KEY=your-api-key-here

# Optional: Server port (default: 3000)
PORT=3000

# Optional: Model overrides
# REASONING_MODEL is used when extended thinking is enabled
# COMPLETION_MODEL is used for standard requests
# If not set, the model from the client request is used
# REASONING_MODEL=anthropic/claude-3.5-sonnet
# COMPLETION_MODEL=anthropic/claude-3-haiku

# Optional: Model mapping (source=target;other=target)
# Maps Anthropic model names to upstream model names
# ANTHROPIC_PROXY_MODEL_MAP=claude-opus-4-6=openai/gpt-4.1;claude-haiku-4-5=openai/gpt-4.1-mini

# Optional: System prompt terms to remove before forwarding upstream
# Use semicolon or newline to separate multiple terms
# ANTHROPIC_PROXY_SYSTEM_PROMPT_IGNORE_TERMS=term1;term2

# Optional: Enable debug logging (true or 1)
# DEBUG=false

# Optional: Enable verbose logging (logs full request/response bodies)
# VERBOSE=false

# Optional: Skip SSL certificate verification (default: false)
# Set to true or 1 to disable SSL certificate validation
# Useful for development environments or self-signed certificates
# SKIP_SSL_VERIFY=false
